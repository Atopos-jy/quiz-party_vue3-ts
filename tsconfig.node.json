{
  "extends": "@tsconfig/node18/tsconfig.json",
  "include": ["vite.config.ts"],
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "types": ["node"],
    "outDir": "./.tsc-out",
    "noEmit": false,
    "emitDeclarationOnly": true
  }
}
